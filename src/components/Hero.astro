---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="hero" aria-label="Lab introduction">
  <div class="container hero__inner">
    <div class="hero__content">
      <p class="section-label reveal" style="animation-delay:0.05s">Human Computer Interaction Lab</p>
      <h1 class="hero__heading reveal" style="animation-delay:0.15s">
        Augmenting<br/>
        <span class="hero__the">the</span> <span class="hero__accent">Human</span> Experience<br/>
        <span class="hero__typeword" aria-hidden="true"></span>
      </h1>
      <p class="hero__sub reveal" style="animation-delay:0.28s">
        We design, build, and study technologies that extend the human senses
        through wearable computing, extended reality, biosensing,
        and cognitive augmentation.
      </p>
      <div class="hero__ctas reveal" style="animation-delay:0.38s">
        <a href="#research" class="btn btn--primary">Our Research</a>
        <a href={`${base}/publications/`} class="btn btn--outline">Publications</a>
      </div>
      <div class="hero__stats reveal" style="animation-delay:0.50s" aria-label="Lab statistics">
        <div class="hero__stat">
          <span class="hero__stat-num">230+</span>
          <span class="hero__stat-label">Publications</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-num">2014</span>
          <span class="hero__stat-label">Founded</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-num">CHI · IMWUT · UIST</span>
          <span class="hero__stat-label">Top venues</span>
        </div>
      </div>
    </div>

    <div class="hero__visual reveal-fade" aria-hidden="true" style="animation-delay:0.2s">
      <div class="hero__orb hero__orb--1"></div>
      <div class="hero__orb hero__orb--2"></div>
      <div class="hero__grid-dots"></div>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  overflow: hidden;
  padding-block: var(--space-2xl);
  padding-top: calc(var(--space-2xl) + 2rem);
  background: var(--color-bg);
}

.hero__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xl);
  align-items: center;
}

.hero__heading {
  font-size: var(--text-hero);
  margin-bottom: var(--space-md);
  line-height: 1.1;
}

.hero__the {
  color: var(--color-text);
}

.hero__accent {
  color: var(--color-accent);
  position: relative;
  display: inline-block;
}

.hero__accent::after {
  content: '';
  position: absolute;
  left: 0; right: 0;
  bottom: 0.05em;
  height: 0.08em;
  background: var(--color-accent);
  opacity: 0.3;
  border-radius: 2px;
}

.hero__sub {
  font-size: clamp(1.05rem, 0.96rem + 0.4vw, 1.25rem);
  color: var(--color-muted);
  max-width: 480px;
  margin-bottom: var(--space-lg);
  line-height: 1.7;
}

.hero__ctas {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
  margin-bottom: var(--space-xl);
}

.hero__stats {
  display: flex;
  gap: var(--space-lg);
  padding-top: var(--space-md);
  border-top: 1px solid var(--color-border);
}

.hero__stat {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.hero__stat-num {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 1.25rem;
  color: var(--color-text);
}

.hero__stat-label {
  font-size: var(--text-small);
  color: var(--color-muted);
}

/* Decorative visual */
.hero__visual {
  position: relative;
  height: 480px;
}

.hero__orb {
  position: absolute;
  filter: blur(64px);
}

.hero__orb--1 {
  width: 420px; height: 400px;
  background: radial-gradient(ellipse at 42% 38%, #fce8da 0%, #d97757 45%, #c06438 80%, #8a3d1e 100%);
  top: 5%; right: -2%;
  opacity: 0.8;
  animation: blob-drift 11s ease-in-out infinite,
             blob-morph 7s ease-in-out infinite;
}

.hero__orb--2 {
  width: 220px; height: 220px;
  background: radial-gradient(circle, #ede8e0, #b5a8a0 70%);
  top: 55%; right: 38%;
  opacity: 0.45;
  border-radius: 50%;
  animation: orb-drift-2 13s ease-in-out infinite;
}

.hero__grid-dots {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, var(--color-border) 1px, transparent 1px);
  background-size: 28px 28px;
  opacity: 0.5;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
}

/* Blob morphs through distinct organic shapes */
@keyframes blob-morph {
  0%   { border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%; }
  14%  { border-radius: 45% 55% 40% 60% / 60% 40% 65% 35%; }
  28%  { border-radius: 55% 45% 65% 35% / 45% 55% 35% 65%; }
  42%  { border-radius: 40% 60% 45% 55% / 55% 45% 60% 40%; }
  57%  { border-radius: 65% 35% 50% 50% / 40% 60% 45% 55%; }
  71%  { border-radius: 50% 50% 35% 65% / 65% 35% 55% 45%; }
  85%  { border-radius: 35% 65% 60% 40% / 50% 50% 40% 60%; }
  100% { border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%; }
}

/* Slow wander across the visual area */
@keyframes blob-drift {
  0%   { transform: translate(0px,   0px)  scale(1);    }
  25%  { transform: translate(-18px, -32px) scale(1.05); }
  50%  { transform: translate(14px,  -18px) scale(0.96); }
  75%  { transform: translate(-10px,  22px) scale(1.03); }
  100% { transform: translate(0px,   0px)  scale(1);    }
}

@keyframes orb-drift-2 {
  0%   { transform: translate(0px,   0px)  scale(1);    }
  40%  { transform: translate(-12px,  18px) scale(1.06); }
  70%  { transform: translate(10px,  -14px) scale(0.95); }
  100% { transform: translate(0px,   0px)  scale(1);    }
}

/* Typewriter word */
.hero__typeword {
  display: inline-block;
  color: var(--color-muted);
  font-size: clamp(1.1rem, 0.9rem + 1vw, 1.75rem);
  font-weight: 400;
  letter-spacing: 0.01em;
  min-height: 1.4em;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.hero__typeword.visible {
  opacity: 1;
}

@keyframes cursor-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

.hero__typeword::after {
  content: '|';
  margin-left: 2px;
  color: var(--color-accent);
  animation: cursor-blink 1s step-end infinite;
}

@media (prefers-reduced-motion: reduce) {
  .hero__orb--1 { animation: none; border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%; }
  .hero__orb--2 { animation: none; }
  .hero__typeword::after { animation: none; }
}

@media (max-width: 768px) {
  .hero__inner {
    grid-template-columns: 1fr;
  }
  .hero__visual { display: none; }
  .hero__stats { flex-wrap: wrap; gap: var(--space-md); }
}
</style>

<script>
const words = [
  'through wearables.',
  'through biosensing.',
  'through extended reality.',
  'through cognitive computing.',
  'through inclusive design.',
];

const el = document.querySelector<HTMLElement>('.hero__typeword');
if (el) {
  let wordIdx = 0;
  let charIdx = 0;
  let deleting = false;

  // Start after hero fade-in
  setTimeout(() => {
    el.classList.add('visible');
    tick();
  }, 900);

  function tick() {
    const word = words[wordIdx];
    if (!deleting) {
      el!.textContent = word.slice(0, charIdx + 1);
      charIdx++;
      if (charIdx === word.length) {
        deleting = true;
        setTimeout(tick, 2200);
      } else {
        setTimeout(tick, 55);
      }
    } else {
      el!.textContent = word.slice(0, charIdx - 1);
      charIdx--;
      if (charIdx === 0) {
        deleting = false;
        wordIdx = (wordIdx + 1) % words.length;
        setTimeout(tick, 300);
      } else {
        setTimeout(tick, 32);
      }
    }
  }
}
</script>
